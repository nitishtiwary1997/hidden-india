# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/hiddenindia?schema=public"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Authentication (Auth.js / NextAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-in-production"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AWS Cloud Services
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_S3_BUCKET_NAME="hiddenindia-media-assets"
AWS_CLOUDFRONT_DOMAIN="https://assets.hiddenindia.online"

# Maps API Keys
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# AI Service Keys (OpenAI / Gemini)
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"
